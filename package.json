{
  "name": "neura-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite .",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "lint:fix": "eslint . --ext ts,tsx --report-unused-disable-directives --fix",
    "lint:strict": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "eslint . --ext ts,tsx --fix && prettier --write .",
    "format:check": "prettier --check .",
    "spell": "cspell \"src/**/*.{ts,tsx,js,jsx,md}\"",
    "type-check": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.894.0",
    "@aws-sdk/s3-request-presigner": "3.894.0",
    "@tailwindcss/typography": "0.5.18",
    "@types/react-router-dom": "5.3.3",
    "axios": "1.11.0",
    "katex": "0.16.22",
    "lucide-react": "0.400.0",
    "mammoth": "1.11.0",
    "oidc-client-ts": "3.3.0",
    "pdfjs-dist": "3.11.174",
    "react": "18.3.1",
    "react-code-blocks": "0.1.6",
    "react-dom": "18.3.1",
    "react-markdown": "10.1.0",
    "react-router-dom": "7.8.2",
    "rehype-katex": "7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "6.0.0",
    "socket.io-client": "4.8.1",
    "turndown": "7.2.1",
    "uuid": "13.0.0",
    "zod": "4.1.5",
    "zustand": "5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "9.34.0",
    "@tailwindcss/postcss": "4.1.12",
    "@types/node": "24.3.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/eslint-plugin": "8.44.0",
    "@typescript-eslint/parser": "8.44.0",
    "@vitejs/plugin-react": "4.3.1",
    "autoprefixer": "10.4.21",
    "cspell": "9.2.1",
    "dotenv": "17.2.2",
    "eslint": "9.36.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "globals": "16.3.0",
    "husky": "9.1.7",
    "lint-staged": "16.1.6",
    "postcss": "8.5.6",
    "prettier": "3.6.2",
    "tailwindcss": "4.1.12",
    "typescript": "5.2.2",
    "vite": "5.3.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "cspell"
    ],
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ]
  }
}
