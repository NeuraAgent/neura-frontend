# API Configuration
VITE_API_GATEWAY_URL=http://localhost:9999
VITE_SOCKET_URL=http://localhost:8000

# OAuth2 Configuration (Optional)
VITE_OAUTH_CLIENT_ID=frontend-client
VITE_OAUTH_AUTHORITY=http://localhost:8011
VITE_OAUTH_REDIRECT_URI=http://localhost:3000/callback
VITE_OAUTH_SILENT_REDIRECT_URI=http://localhost:3000/silent-callback
VITE_OAUTH_POST_LOGOUT_REDIRECT_URI=http://localhost:3000

# Feature Flags
VITE_ENABLE_OAUTH=false
VITE_ENABLE_INTRO_TOUR=true

# Environment
VITE_ENV=development
